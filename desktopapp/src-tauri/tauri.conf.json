{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VTracer Desktop",
  "version": "0.1.0",
  "identifier": "org.visioncortex.vtracer.desktop",
  "build": {
    "frontendDist": "../../webapp/app/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VTracer Desktop",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "minWidth": 1120,
        "minHeight": 720,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.png"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
